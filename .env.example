# Roam'un mevcut Supabase projesi (mobil uygulamayla aynı).
# Değerler: roam/.env.local içindeki EXPO_PUBLIC_SUPABASE_* değerleriyle aynı.
# NOT: anon/publishable key istemciye gömülmek için tasarlanmıştır; güvenlik RLS ile sağlanır
# (waitlist tablosunda yalnızca INSERT politikası var, liste dışarıdan okunamaz).
PUBLIC_SUPABASE_URL=https://XXXX.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXX
