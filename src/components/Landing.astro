---
// Landing page içeriği — TR ve EN sayfaları bu bileşeni farklı locale ile render eder.
import { type Locale, useTranslations } from '../i18n/ui';
import Waitlist from './Waitlist.astro';
import PhoneMockup from './PhoneMockup.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const steps = [
  { n: '1', title: t('how.step1.title'), desc: t('how.step1.desc'), emoji: '🗺️' },
  { n: '2', title: t('how.step2.title'), desc: t('how.step2.desc'), emoji: '🚶' },
  { n: '3', title: t('how.step3.title'), desc: t('how.step3.desc'), emoji: '🏅' },
];

const features = [
  { title: t('features.map.title'), desc: t('features.map.desc'), emoji: '📍' },
  { title: t('features.badges.title'), desc: t('features.badges.desc'), emoji: '🏆' },
  { title: t('features.categories.title'), desc: t('features.categories.desc'), emoji: '🧭' },
  { title: t('features.i18n.title'), desc: t('features.i18n.desc'), emoji: '🌍' },
];

// Uygulamadaki gerçek kategoriler — ikonlar public/, renkler ve açıklamalar
// uygulamanın veritabanındaki (seed) değerlerle birebir aynı kaynaktan.
const categories = [
  {
    label: t('categories.gastronomy'),
    desc: t('categories.gastronomy.desc'),
    color: '#E2725B',
    icon: '/gastronomy.svg',
  },
  {
    label: t('categories.scenery'),
    desc: t('categories.scenery.desc'),
    color: '#F4A261',
    icon: '/scenery.svg',
  },
  {
    label: t('categories.nature'),
    desc: t('categories.nature.desc'),
    color: '#2A9D8F',
    icon: '/nature.svg',
  },
  {
    label: t('categories.craft'),
    desc: t('categories.craft.desc'),
    color: '#A0522D',
    icon: '/craft.svg',
  },
  {
    label: t('categories.nightlife'),
    desc: t('categories.nightlife.desc'),
    color: '#6A0DAD',
    icon: '/nightlife.svg',
  },
  {
    label: t('categories.hidden'),
    desc: t('categories.hidden.desc'),
    color: '#3D5A80',
    icon: '/hidden.svg',
  },
  {
    label: t('categories.heritage'),
    desc: t('categories.heritage.desc'),
    color: '#B08968',
    icon: '/famous.svg',
  },
  {
    label: t('categories.adventure'),
    desc: t('categories.adventure.desc'),
    color: '#D62828',
    icon: '/adventure.svg',
  },
  {
    label: t('categories.movie'),
    desc: t('categories.movie.desc'),
    color: '#264653',
    icon: '/movie.svg',
  },
  {
    label: t('categories.holyroute'),
    desc: t('categories.holyroute.desc'),
    color: '#8D99AE',
    icon: '/holyroute.svg',
  },
];

const faqs = [
  { q: t('faq.q1'), a: t('faq.a1') },
  { q: t('faq.q2'), a: t('faq.a2') },
  { q: t('faq.q3'), a: t('faq.a3') },
  { q: t('faq.q4'), a: t('faq.a4') },
  { q: t('faq.q5'), a: t('faq.a5') },
  { q: t('faq.q6'), a: t('faq.a6') },
];
---

{/* ── Hero ── */}
<section class="relative overflow-hidden bg-navy">
  {/* Dekoratif zemin — yavaşça nefes alan ışık lekeleri */}
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="animate-glow absolute -left-24 -top-24 h-72 w-72 rounded-full bg-coral/20 blur-3xl"></div>
    <div class="animate-glow-delayed absolute -bottom-32 -right-16 h-96 w-96 rounded-full bg-pin-manzara/10 blur-3xl"></div>
  </div>

  <div
    class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24"
  >
    <div class="text-center lg:text-left">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-sm font-medium text-white"
      >
        <span class="h-2 w-2 animate-pulse rounded-full bg-coral"></span>
        {t('hero.badge')}
      </span>

      <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl">
        {t('hero.title')}
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/75 lg:mx-0">
        {t('hero.subtitle')}
      </p>

      <div class="mt-8">
        <Waitlist locale={locale} />
        <p class="mt-3 text-sm text-white/50">{t('hero.social_proof')}</p>
        <p
          class="mx-auto mt-4 inline-flex max-w-md items-start gap-2 rounded-2xl border border-amber-300/25 bg-amber-300/10 px-4 py-2.5 text-left text-sm font-medium text-amber-200 lg:mx-0"
        >
          <span aria-hidden="true">🏅</span>
          {t('waitlist.first100')}
        </p>
      </div>
    </div>

    <div class="hidden justify-center lg:flex">
      <PhoneMockup locale={locale} />
    </div>
  </div>
</section>

{/* ── Nasıl çalışır ── */}
<section id="nasil-calisir" class="scroll-mt-20 bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div data-reveal>
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-navy sm:text-4xl">
        {t('how.title')}
      </h2>
      <p class="mt-3 text-center text-lg text-ink-mid">{t('how.subtitle')}</p>
    </div>

    <ol class="mt-12 grid gap-8 sm:grid-cols-3">
      {
        steps.map((step, i) => (
          <li
            class="relative rounded-3xl bg-canvas p-8 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-navy/10"
            data-reveal
            style={`--reveal-delay: ${i * 90}ms`}
          >
            <div class="flex items-center gap-4">
              <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-coral text-xl font-extrabold text-white">
                {step.n}
              </span>
              <span class="text-3xl" aria-hidden="true">
                {step.emoji}
              </span>
            </div>
            <h3 class="mt-5 text-xl font-bold text-navy">{step.title}</h3>
            <p class="mt-2 leading-relaxed text-ink-mid">{step.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

{/* ── Özellikler ── */}
<section id="ozellikler" class="scroll-mt-20 bg-canvas py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div data-reveal>
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-navy sm:text-4xl">
        {t('features.title')}
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-lg text-ink-mid">
        {t('features.subtitle')}
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        features.map((f, i) => (
          <article
            class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-navy/5 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-navy/10"
            data-reveal
            style={`--reveal-delay: ${i * 70}ms`}
          >
            <span class="text-3xl" aria-hidden="true">
              {f.emoji}
            </span>
            <h3 class="mt-4 text-xl font-bold text-navy">{f.title}</h3>
            <p class="mt-2 leading-relaxed text-ink-mid">{f.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

{/* ── Kategoriler ── */}
<section id="kategoriler" class="scroll-mt-20 bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center" data-reveal>
      <span class="text-xs font-bold uppercase tracking-widest text-coral">
        {t('categories.eyebrow')}
      </span>
      <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-navy sm:text-4xl">
        {t('categories.title')}
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-ink-mid">{t('categories.subtitle')}</p>
    </div>

    <ul class="mt-12 grid grid-cols-2 gap-4 sm:gap-5 xl:grid-cols-5">
      {
        categories.map((c, i) => (
          <li
            class="rounded-3xl border p-5 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-navy/10 sm:p-6"
            style={`background-color: color-mix(in srgb, ${c.color} 7%, white); border-color: color-mix(in srgb, ${c.color} 22%, transparent); --reveal-delay: ${i * 50}ms`}
            data-reveal
          >
            <span
              class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white shadow-sm"
              style={`box-shadow: 0 1px 3px color-mix(in srgb, ${c.color} 35%, transparent)`}
            >
              <img src={c.icon} alt="" width="22" height="22" loading="lazy" />
            </span>
            <h3 class="mt-4 text-base font-bold text-navy">{c.label}</h3>
            <p class="mt-1.5 text-xs leading-relaxed text-ink-mid sm:text-sm">{c.desc}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

{/* ── Waitlist CTA ── */}
<section id="katil" class="scroll-mt-20 bg-navy py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
    <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
      {t('waitlist.title')}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-white/75">{t('waitlist.subtitle')}</p>
    <p
      class="mx-auto mt-5 inline-flex items-start gap-2 rounded-2xl border border-amber-300/25 bg-amber-300/10 px-4 py-2.5 text-left text-sm font-medium text-amber-200"
    >
      <span aria-hidden="true">🏅</span>
      {t('waitlist.first100')}
    </p>
    <div class="mt-8">
      <Waitlist locale={locale} />
    </div>
  </div>
</section>

{/* ── SSS ── */}
<section id="sss" class="scroll-mt-20 bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <h2 class="text-center text-3xl font-extrabold tracking-tight text-navy sm:text-4xl">
      {t('faq.title')}
    </h2>

    <div class="mt-10 space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-2xl bg-canvas px-6 py-4 open:pb-6">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-navy [&::-webkit-details-marker]:hidden">
              {faq.q}
              <span
                class="text-coral transition-transform duration-200 group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 leading-relaxed text-ink-mid">{faq.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Scroll-reveal: .reveal sınıfı yalnızca burada eklenir → JS kapalıyken
  // içerik hiçbir zaman gizlenmez. Reduced-motion tercihine saygılı.
  const elements = document.querySelectorAll<HTMLElement>('[data-reveal]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reducedMotion && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' },
    );

    for (const el of elements) {
      el.classList.add('reveal');
      observer.observe(el);
    }
  }
</script>
