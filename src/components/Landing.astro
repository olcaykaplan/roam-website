---
// Landing page içeriği — TR ve EN sayfaları bu bileşeni farklı locale ile render eder.
import { type Locale, useTranslations } from '../i18n/ui';
import Waitlist from './Waitlist.astro';
import PhoneMockup from './PhoneMockup.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const steps = [
  { n: '1', title: t('how.step1.title'), desc: t('how.step1.desc'), emoji: '🗺️' },
  { n: '2', title: t('how.step2.title'), desc: t('how.step2.desc'), emoji: '🚶' },
  { n: '3', title: t('how.step3.title'), desc: t('how.step3.desc'), emoji: '🏅' },
];

const features = [
  { title: t('features.map.title'), desc: t('features.map.desc'), emoji: '📍' },
  { title: t('features.badges.title'), desc: t('features.badges.desc'), emoji: '🏆' },
  { title: t('features.categories.title'), desc: t('features.categories.desc'), emoji: '🧭' },
  { title: t('features.i18n.title'), desc: t('features.i18n.desc'), emoji: '🌍' },
];

// Uygulamadaki gerçek kategoriler — ikonlar public/, renkler uygulamanın
// veritabanındaki pin_color değerleriyle birebir aynı.
const categories = [
  { label: t('categories.gastronomy'), color: '#E2725B', icon: '/gastronomy.svg' },
  { label: t('categories.scenery'), color: '#F4A261', icon: '/scenery.svg' },
  { label: t('categories.nature'), color: '#2A9D8F', icon: '/nature.svg' },
  { label: t('categories.craft'), color: '#A0522D', icon: '/craft.svg' },
  { label: t('categories.nightlife'), color: '#6A0DAD', icon: '/nightlife.svg' },
  { label: t('categories.hidden'), color: '#3D5A80', icon: '/hidden.svg' },
  { label: t('categories.heritage'), color: '#B08968', icon: '/famous.svg' },
  { label: t('categories.adventure'), color: '#D62828', icon: '/adventure.svg' },
  { label: t('categories.movie'), color: '#264653', icon: '/movie.svg' },
  { label: t('categories.holyroute'), color: '#8D99AE', icon: '/holyroute.svg' },
];

const faqs = [
  { q: t('faq.q1'), a: t('faq.a1') },
  { q: t('faq.q2'), a: t('faq.a2') },
  { q: t('faq.q3'), a: t('faq.a3') },
  { q: t('faq.q4'), a: t('faq.a4') },
  { q: t('faq.q5'), a: t('faq.a5') },
  { q: t('faq.q6'), a: t('faq.a6') },
];
---

{/* ── Hero ── */}
<section class="relative overflow-hidden bg-navy">
  {/* Dekoratif zemin */}
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -left-24 -top-24 h-72 w-72 rounded-full bg-coral/20 blur-3xl"></div>
    <div class="absolute -bottom-32 -right-16 h-96 w-96 rounded-full bg-pin-manzara/10 blur-3xl"></div>
  </div>

  <div
    class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24"
  >
    <div class="text-center lg:text-left">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-sm font-medium text-white"
      >
        <span class="h-2 w-2 animate-pulse rounded-full bg-coral"></span>
        {t('hero.badge')}
      </span>

      <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl">
        {t('hero.title')}
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/75 lg:mx-0">
        {t('hero.subtitle')}
      </p>

      <div class="mt-8">
        <Waitlist locale={locale} />
        <p class="mt-3 text-sm text-white/50">{t('hero.social_proof')}</p>
        <p
          class="mx-auto mt-4 inline-flex max-w-md items-start gap-2 rounded-2xl border border-amber-300/25 bg-amber-300/10 px-4 py-2.5 text-left text-sm font-medium text-amber-200 lg:mx-0"
        >
          <span aria-hidden="true">🏅</span>
          {t('waitlist.first100')}
        </p>
      </div>
    </div>

    <div class="hidden justify-center lg:flex">
      <PhoneMockup />
    </div>
  </div>
</section>

{/* ── Nasıl çalışır ── */}
<section id="nasil-calisir" class="scroll-mt-20 bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 class="text-center text-3xl font-extrabold tracking-tight text-navy sm:text-4xl">
      {t('how.title')}
    </h2>
    <p class="mt-3 text-center text-lg text-ink-mid">{t('how.subtitle')}</p>

    <ol class="mt-12 grid gap-8 sm:grid-cols-3">
      {
        steps.map((step) => (
          <li class="relative rounded-3xl bg-canvas p-8">
            <div class="flex items-center gap-4">
              <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-coral text-xl font-extrabold text-white">
                {step.n}
              </span>
              <span class="text-3xl" aria-hidden="true">
                {step.emoji}
              </span>
            </div>
            <h3 class="mt-5 text-xl font-bold text-navy">{step.title}</h3>
            <p class="mt-2 leading-relaxed text-ink-mid">{step.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

{/* ── Özellikler ── */}
<section id="ozellikler" class="scroll-mt-20 bg-canvas py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 class="text-center text-3xl font-extrabold tracking-tight text-navy sm:text-4xl">
      {t('features.title')}
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-lg text-ink-mid">
      {t('features.subtitle')}
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        features.map((f) => (
          <article class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-navy/5">
            <span class="text-3xl" aria-hidden="true">
              {f.emoji}
            </span>
            <h3 class="mt-4 text-xl font-bold text-navy">{f.title}</h3>
            <p class="mt-2 leading-relaxed text-ink-mid">{f.desc}</p>
          </article>
        ))
      }
    </div>

    {/* Kategoriler */}
    <h3 class="mt-16 text-center text-xl font-bold text-navy">{t('categories.title')}</h3>
    <ul class="mt-6 flex flex-wrap justify-center gap-3">
      {
        categories.map((c) => (
          <li
            class="flex items-center gap-2.5 rounded-full py-1.5 pl-1.5 pr-4 text-sm font-semibold text-white shadow-sm"
            style={`background-color: ${c.color}`}
          >
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-white">
              <img src={c.icon} alt="" width="20" height="20" loading="lazy" />
            </span>
            {c.label}
          </li>
        ))
      }
    </ul>
  </div>
</section>

{/* ── Waitlist CTA ── */}
<section id="katil" class="scroll-mt-20 bg-navy py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
    <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
      {t('waitlist.title')}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-white/75">{t('waitlist.subtitle')}</p>
    <p
      class="mx-auto mt-5 inline-flex items-start gap-2 rounded-2xl border border-amber-300/25 bg-amber-300/10 px-4 py-2.5 text-left text-sm font-medium text-amber-200"
    >
      <span aria-hidden="true">🏅</span>
      {t('waitlist.first100')}
    </p>
    <div class="mt-8">
      <Waitlist locale={locale} />
    </div>
  </div>
</section>

{/* ── SSS ── */}
<section id="sss" class="scroll-mt-20 bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <h2 class="text-center text-3xl font-extrabold tracking-tight text-navy sm:text-4xl">
      {t('faq.title')}
    </h2>

    <div class="mt-10 space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-2xl bg-canvas px-6 py-4 open:pb-6">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-navy [&::-webkit-details-marker]:hidden">
              {faq.q}
              <span
                class="text-coral transition-transform duration-200 group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 leading-relaxed text-ink-mid">{faq.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
