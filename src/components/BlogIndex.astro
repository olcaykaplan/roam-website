---
// Blog liste sayfası içeriği — TR ve EN indeksleri bunu kullanır.
import { type Locale, useTranslations } from '../i18n/ui';
import { type BlogPost, postPath, readingMinutes, formatDate } from '../lib/blog';

interface Props {
  locale: Locale;
  posts: BlogPost[];
}

const { locale, posts } = Astro.props;
const t = useTranslations(locale);
---

<section class="bg-navy py-14">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h1 class="text-4xl font-extrabold tracking-tight text-white">{t('blog.heading')}</h1>
    <p class="mt-3 max-w-2xl text-lg text-white/75">{t('blog.subheading')}</p>
  </div>
</section>

<section class="bg-canvas py-12 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <article class="group flex flex-col rounded-3xl bg-white p-7 shadow-sm ring-1 ring-navy/5 transition-shadow hover:shadow-md">
            <div class="flex flex-wrap gap-2">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="rounded-full bg-coral-light px-3 py-1 text-xs font-semibold text-coral-dark">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="mt-4 text-xl font-bold leading-snug text-navy">
              <a href={postPath(post)} class="after:absolute after:inset-0 relative group-hover:text-coral-dark">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-3 flex-1 leading-relaxed text-ink-mid">{post.data.description}</p>
            <p class="mt-5 text-sm text-ink-dim">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate, locale)}
              </time>
              {' · '}
              {readingMinutes(post.body)} {t('blog.minread')}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
