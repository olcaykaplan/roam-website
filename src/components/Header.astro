---
import { SITE_NAME } from '../consts.js';
import { type Locale, locales, localeNames, useTranslations, localePath } from '../i18n/ui';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
  /** Dil değiştiricinin hedefi — sayfanın diğer dillerdeki karşılıkları */
  translations?: Partial<Record<Locale, string>>;
}

const { locale, translations } = Astro.props;
const t = useTranslations(locale);

const home = localePath(locale);
const blog = localePath(locale, '/blog');

// Dil değiştirici: çevirisi olan sayfada karşılığa, yoksa o dilin ana sayfasına
const languageLinks = locales
  .filter((l) => l !== locale)
  .map((l) => ({ code: l, name: localeNames[l], href: translations?.[l] ?? localePath(l) }));

const nav = [
  { href: `${home}#ozellikler`, label: t('nav.features') },
  { href: `${home}#nasil-calisir`, label: t('nav.how') },
  { href: `${home}#sss`, label: t('nav.faq') },
  { href: blog, label: t('nav.blog') },
];
---

<header class="sticky top-0 z-50 border-b border-navy/5 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href={home} class="flex items-center gap-2" aria-label={SITE_NAME}>
      <Logo class="h-8 w-8" />
      <span class="text-xl font-extrabold tracking-tight text-navy">{SITE_NAME}</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Ana menü">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-ink-mid transition-colors hover:text-navy"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <details class="group relative">
        <summary
          class="flex cursor-pointer list-none items-center gap-1 rounded-full border border-navy/10 px-3 py-1.5 text-xs font-semibold text-ink-mid transition-colors hover:border-navy/30 hover:text-navy [&::-webkit-details-marker]:hidden"
          aria-label={localeNames[locale]}
        >
          {locale.toUpperCase()}
          <span class="text-[0.6rem] transition-transform group-open:rotate-180" aria-hidden="true">
            ▾
          </span>
        </summary>
        <ul
          class="absolute right-0 z-50 mt-2 w-32 overflow-hidden rounded-2xl border border-navy/10 bg-white py-1 shadow-lg"
        >
          {
            languageLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="block px-4 py-2 text-sm font-medium text-ink-mid hover:bg-canvas hover:text-navy"
                >
                  {l.name}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      <a
        href={`${home}#katil`}
        class="hidden rounded-full bg-coral px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-coral-dark sm:inline-block"
      >
        {t('nav.join')}
      </a>
    </div>
  </div>
</header>
