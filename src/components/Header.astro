---
import { SITE_NAME } from '../consts.js';
import { type Locale, useTranslations, localePath, defaultLocale } from '../i18n/ui';
import Logo from './Logo.astro';

interface Props {
  locale: Locale;
  /** Dil değiştiricinin hedefi — sayfanın diğer dildeki karşılığı */
  translations?: Partial<Record<Locale, string>>;
}

const { locale, translations } = Astro.props;
const t = useTranslations(locale);

const home = localePath(locale);
const blog = localePath(locale, '/blog');

// Dil değiştirici: çevirisi olan sayfada karşılığa, yoksa diğer dilin ana sayfasına
const otherLocale: Locale = locale === 'tr' ? 'en' : 'tr';
const switchHref = translations?.[otherLocale] ?? localePath(otherLocale);

const nav = [
  { href: `${home}#ozellikler`, label: t('nav.features') },
  { href: `${home}#nasil-calisir`, label: t('nav.how') },
  { href: `${home}#sss`, label: t('nav.faq') },
  { href: blog, label: t('nav.blog') },
];
---

<header class="sticky top-0 z-50 border-b border-navy/5 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href={home} class="flex items-center gap-2" aria-label={SITE_NAME}>
      <Logo class="h-8 w-8" />
      <span class="text-xl font-extrabold tracking-tight text-navy">{SITE_NAME}</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Ana menü">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-ink-mid transition-colors hover:text-navy"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={switchHref}
        class="rounded-full border border-navy/10 px-3 py-1.5 text-xs font-semibold text-ink-mid transition-colors hover:border-navy/30 hover:text-navy"
        aria-label={t('lang.switch')}
      >
        {t('lang.switch')}
      </a>
      <a
        href={`${home}#katil`}
        class="hidden rounded-full bg-coral px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-coral-dark sm:inline-block"
      >
        {t('nav.join')}
      </a>
    </div>
  </div>
</header>
