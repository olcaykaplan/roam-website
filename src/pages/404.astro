---
import Base from '../layouts/Base.astro';
import { useTranslations } from '../i18n/ui';

const locale = 'tr' as const;
const t = useTranslations(locale);
---

<Base locale={locale} title={`404 — ${t('notfound.title')}`} description={t('notfound.desc')} noindex>
  <section class="flex min-h-[50vh] items-center justify-center bg-canvas px-4 py-20">
    <div class="text-center">
      <p class="text-7xl font-extrabold text-coral">404</p>
      <h1 class="mt-4 text-2xl font-bold text-navy">{t('notfound.title')}</h1>
      <p class="mt-2 text-ink-mid">{t('notfound.desc')}</p>
      <a
        href="/"
        class="mt-8 inline-block rounded-full bg-coral px-6 py-3 font-semibold text-white hover:bg-coral-dark"
      >
        {t('notfound.home')}
      </a>
    </div>
  </section>
</Base>
