---
// Blog yazısı şablonu — BlogPosting + Breadcrumb JSON-LD, hreflang, alt CTA.
import Base from './Base.astro';
import Waitlist from '../components/Waitlist.astro';
import { SITE_NAME } from '../consts.js';
import { type Locale, useTranslations, localePath, defaultLocale } from '../i18n/ui';
import {
  type BlogPost,
  postPath,
  postLocale,
  findTranslations,
  getPublishedPosts,
  readingMinutes,
  formatDate,
} from '../lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const locale: Locale = postLocale(post);
const t = useTranslations(locale);

// hreflang: her dil kendi yoluna; çevirisi olan tüm diller listeye girer.
const translations: Partial<Record<Locale, string>> = { [locale]: postPath(post) };
for (const tr of await findTranslations(post)) {
  translations[postLocale(tr)] = postPath(tr);
}
const hasTranslation = Object.keys(translations).length > 1;

const blogHome = localePath(locale, '/blog');
const minutes = readingMinutes(post.body);

// İlgili yazılar — okuyucuyu sitede tutar: önce ortak etiketli, sonra en yeni.
const sharedTags = (p: BlogPost) =>
  p.data.tags.filter((tag) => post.data.tags.includes(tag)).length;
const related = (await getPublishedPosts(locale))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => sharedTags(b) - sharedTags(a) || b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const postingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  inLanguage: locale,
  author: { '@type': 'Organization', name: post.data.author },
  publisher: { '@type': 'Organization', name: SITE_NAME },
  mainEntityOfPage: new URL(postPath(post), Astro.site).toString(),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: SITE_NAME,
      item: new URL(localePath(locale), Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: new URL(blogHome, Astro.site).toString(),
    },
    { '@type': 'ListItem', position: 3, name: post.data.title },
  ],
};
---

<Base
  locale={locale}
  title={`${post.data.title} — ${SITE_NAME} Blog`}
  description={post.data.description}
  translations={hasTranslation || locale === defaultLocale ? translations : undefined}
  ogType="article"
  jsonLd={[postingLd, breadcrumbLd]}
>
  <article class="bg-white">
    <header class="bg-navy py-14">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <a href={blogHome} class="text-sm font-medium text-white/60 hover:text-white">
          {t('blog.backtoblog')}
        </a>
        <h1 class="mt-4 text-3xl font-extrabold leading-tight tracking-tight text-white sm:text-4xl">
          {post.data.title}
        </h1>
        <p class="mt-4 text-sm text-white/60">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate, locale)}
          </time>
          {' · '}{minutes} {t('blog.minread')}{' · '}{post.data.author}
        </p>
      </div>
    </header>

    <div
      class="prose prose-lg mx-auto max-w-3xl px-4 py-12 sm:px-6 prose-headings:font-extrabold prose-headings:tracking-tight prose-headings:text-navy prose-a:text-coral-dark prose-strong:text-navy"
    >
      <slot />
    </div>

    {/* Yazı altı dönüşüm CTA'sı — blog trafiğini uygulama kullanıcısına çevirir */}
    <aside class="mx-auto max-w-3xl px-4 pb-12 sm:px-6">
      <div class="rounded-3xl bg-navy p-8 text-center sm:p-10">
        <h2 class="text-2xl font-extrabold tracking-tight text-white">{t('blog.cta.title')}</h2>
        <p class="mx-auto mt-3 max-w-lg text-white/75">{t('blog.cta.desc')}</p>
        <div class="mt-6">
          <Waitlist locale={locale} compact />
        </div>
      </div>
    </aside>

    {/* İlgili yazılar — okuyucuyu bir sonraki rehbere taşır */}
    {
      related.length > 0 && (
        <nav class="mx-auto max-w-3xl px-4 pb-16 sm:px-6" aria-label={t('blog.related')}>
          <h2 class="text-xl font-extrabold tracking-tight text-navy">{t('blog.related')}</h2>
          <div class="mt-5 grid gap-4 sm:grid-cols-3">
            {related.map((p) => (
              <a
                href={postPath(p)}
                class="group rounded-2xl bg-canvas p-5 ring-1 ring-navy/5 transition-shadow hover:shadow-md"
              >
                <h3 class="font-bold leading-snug text-navy group-hover:text-coral-dark">
                  {p.data.title}
                </h3>
                <p class="mt-2 text-sm text-ink-mid">
                  {readingMinutes(p.body)} {t('blog.minread')}
                </p>
              </a>
            ))}
          </div>
        </nav>
      )
    }
  </article>
</Base>
